# ==========================================
# Server
# ==========================================
NODE_ENV=development
PORT=5000
API_PREFIX=/api/v1

# ==========================================
# Database
# ==========================================
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/mini-erp
# Atlas:
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/mini-erp?retryWrites=true&w=majority

# ==========================================
# JWT
# ==========================================
JWT_SECRET=replace_with_a_long_random_secret_string
JWT_EXPIRES_IN=1d
JWT_REFRESH_SECRET=replace_with_a_different_long_random_secret
JWT_REFRESH_EXPIRES_IN=7d

# ==========================================
# Bcrypt
# ==========================================
BCRYPT_SALT_ROUNDS=10

# ==========================================
# CORS
# ==========================================
CLIENT_URL=http://localhost:5173

# ==========================================
# File Upload
# ==========================================
MAX_FILE_SIZE_MB=2
UPLOAD_DIR=uploads

CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# ==========================================
# Rate Limiting
# ==========================================
RATE_LIMIT_WINDOW_MS=900000
RATE_LIMIT_MAX_REQUESTS=100

# ==========================================
# Seed / Admin
# ==========================================
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=change_this_password
SEED_MANAGER_EMAIL=manager@example.com
SEED_MANAGER_PASSWORD=change_this_password
SEED_EMPLOYEE_EMAIL=employee@example.com
SEED_EMPLOYEE_PASSWORD=change_this_password
